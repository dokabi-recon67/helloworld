# Build artifacts
build/
dist/
*.exe
*.app
*.dmg
*.msi
*.o
*.obj
*.lib
*.dll
*.so
*.dylib

# IDE and editor
.idea/
.vscode/
*.swp
*.swo
*~
.cursor/
*.user
*.suo

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ============================================
# SECURITY - NEVER COMMIT THESE
# ============================================

# SSH Keys - NEVER commit private keys!
*.pem
*.key
*.ppk
id_rsa
id_ed25519
id_ecdsa
id_dsa
*.pub
known_hosts
authorized_keys

# TLS/SSL certificates
*.crt
*.cer
*.p12
*.pfx

# Config files with credentials
config.json
profiles.json
servers.json
settings.json
helloworld.conf
*.conf

# Environment and secrets
.env
.env.*
secrets/
credentials/
private/

# User data directories
%APPDATA%/HelloWorld/
~/.helloworld/
~/.config/helloworld/

# Logs (may contain IPs)
*.log
logs/

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Python (legacy)
__pycache__/
*.py[cod]
venv/
.venv/

# Node (if any)
node_modules/

# ============================================
# EXAMPLES ARE OK TO COMMIT
# ============================================
!config.example.json
!servers.example.json
